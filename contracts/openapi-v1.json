          "user_id": {
            "type": "string",
            "format": "uuid",
            "title": "User Id"
          },
          "origin_iata": {
            "type": "string",
            "maxLength": 3,
            "minLength": 3,
            "title": "Origin Iata"
          },
          "destination_iata": {
            "type": "string",
            "maxLength": 3,
            "minLength": 3,
            "title": "Destination Iata"
          },
          "depart_date_start": {
            "type": "string",
            "format": "date-time",
            "title": "Depart Date Start"
          },
          "depart_date_end": {
            "type": "string",
            "format": "date-time",
            "title": "Depart Date End"
          },
          "max_price": {
            "anyOf": [
              {
                "type": "number",
                "exclusiveMinimum": 0.0
              },
              {
                "type": "string",
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$"
              }
            ],
            "title": "Max Price"
          },
          "currency": {
            "type": "string",
            "maxLength": 3,
            "minLength": 3,
            "title": "Currency",
            "default": "USD"
          },
          "check_interval_min": {
            "type": "integer",
